{
  "build": {
    "content": [
      {
        "files": [
          "**/*.md",
          "**/toc.yml"
        ],
        "src": "de-de",
        "dest": "de-de"
      }
    ],
    "resource": [
      {
        "files": [
          "index.html",
          "images/**",
          "**/images/**",
          "public/**"
        ]
      }
    ],
    "output": "_site",
    "globalMetadata": {
      "_appTitle": "BlackBox Docs (test)",
      "_appBasePath": "/mumdat_docs/",
      "_enableSearch": true,
      "_disableContribution": true
    },
    "globalMetadataFiles": [],
    "fileMetadataFiles": [],
    "template": [
      "default"
    ],
    "postProcessors": [],
    "markdownEngineName": "markdig",
    "noLangKeyword": false,
    "keepFileLink": false,
    "cleanupCacheHistory": false,
    "disableGitFeatures": false
  }
}
